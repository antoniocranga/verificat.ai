{
  "name": "verificat-monorepo",
  "private": true,
  "packageManager": "pnpm@9.1.4",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "turbo": "^2.9.18"
  },
  "lint-staged": {
    "*.{js,ts,tsx,mjs}": "pnpm lint --",
    "*.{json,md}": "prettier --write"
  },
  "pnpm": {
    "overrides": {
      "shell-quote": "^1.8.4",
      "tar": "^7.5.16",
      "multer": "^2.2.0",
      "@opentelemetry/auto-instrumentations-node": "^0.75.0",
      "@opentelemetry/sdk-node": "^0.217.0",
      "tmp": "^0.2.6",
      "protobufjs": "^8.4.1"
    }
  }
}
